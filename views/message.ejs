<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style>
    body { font-family: system-ui, sans-serif; background:#10131a; color:white; display:grid; place-items:center; min-height:100vh; margin:0; }
    .card { width:min(620px, 92vw); background:#181d29; border:1px solid #2a3142; border-radius:20px; padding:28px; box-shadow:0 20px 70px rgba(0,0,0,.35); }
    p { line-height:1.55; color:#d8deea; }
  </style>
</head>
<body>
  <main class="card">
    <h1><%= title %></h1>
    <p><%= message %></p>
  </main>
</body>
</html>
